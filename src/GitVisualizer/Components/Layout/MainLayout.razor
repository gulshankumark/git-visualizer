@inherits LayoutComponentBase
@inject IThemeService ThemeService
@inject IGitSimulatorService GitSimulator
@inject IServiceWorkerUpdateService ServiceWorkerUpdateService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<MudLayout Style="height:100vh; overflow:hidden;">
    <MudAppBar Elevation="0" Fixed="true" Dense="true" Style="height:48px;">
        <MudText Typo="Typo.h6" Style="margin-right: auto; font-family: var(--gitvis-font-mono);">
            git-visualizer
        </MudText>
        <!-- Desktop toolbar: Reset, Replay, Theme, GitHub -->
        <div class="toolbar-desktop-only">
            <MudTooltip Text="Reset sandbox (Ctrl+Shift+R)">
                <MudIconButton Icon="@Icons.Material.Outlined.RestartAlt"
                               OnClick="@(() => _isResetDialogOpen = true)"
                               aria-label="Reset sandbox" />
            </MudTooltip>
            <MudTooltip Text="Replay mode (Ctrl+Shift+P)">
                <MudIconButton Icon="@Icons.Material.Outlined.PlayCircleOutline"
                               Disabled="true"
                               aria-label="Replay mode" />
            </MudTooltip>
            <MudTooltip Text="@(ThemeService.IsDarkMode ? "Switch to light theme" : "Switch to dark theme")">
                <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                               OnClick="@ThemeService.ToggleAsync"
                               aria-label="@(ThemeService.IsDarkMode ? "Switch to light theme" : "Switch to dark theme")" />
            </MudTooltip>
            <MudTooltip Text="View source on GitHub">
                <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
                               Href="https://github.com/gulshankumark/git-visualizer"
                               Target="_blank"
                               rel="noopener noreferrer"
                               aria-label="View source on GitHub" />
            </MudTooltip>
        </div>

        <!-- Mobile hamburger menu (< 768px only) -->
        <div class="toolbar-mobile-only">
            <MudMenu Icon="@Icons.Material.Filled.Menu" aria-label="Open menu">
                <MudMenuItem OnClick="@(() => _isResetDialogOpen = true)">Reset sandbox</MudMenuItem>
                <MudMenuItem Disabled="true">Replay mode</MudMenuItem>
                <MudMenuItem OnClick="@ThemeService.ToggleAsync">
                    @(ThemeService.IsDarkMode ? "Switch to light theme" : "Switch to dark theme")
                </MudMenuItem>
                <MudMenuItem Href="https://github.com/gulshankumark/git-visualizer"
                             Target="_blank">
                    View source on GitHub
                </MudMenuItem>
            </MudMenu>
        </div>
    </MudAppBar>
    <MudMainContent Style="height:calc(100vh - 48px); overflow:hidden;">
        @Body
    </MudMainContent>
</MudLayout>

<ResetConfirmDialog @bind-IsOpen="_isResetDialogOpen"
                    OnConfirm="HandleResetConfirm"
                    OnCancel="HandleResetCancel" />

@code {
    private bool _isResetDialogOpen;

    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        ServiceWorkerUpdateService.UpdateDetected += OnServiceWorkerUpdateDetected;

        try
        {
            await ServiceWorkerUpdateService.InitializeAsync();
            System.Diagnostics.Debug.WriteLine("[MainLayout] Service Worker update detection initialized");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[MainLayout] Error initializing service worker update detection: {ex.Message}");
        }
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    private void OnServiceWorkerUpdateDetected(object? sender, EventArgs e)
    {
        System.Diagnostics.Debug.WriteLine("[MainLayout] Service Worker update detected");
        InvokeAsync(async () =>
        {
            // Show update notification - reload will happen after a delay
            Snackbar.Add("A new version is available. Reloading in 3 seconds...", Severity.Info);
            await Task.Delay(3000);
            await ServiceWorkerUpdateService.ReloadWithNewVersionAsync();
        });
    }

    private async Task HandleResetConfirm()
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        await GitSimulator.ResetAsync();
        sw.Stop();
        
        System.Diagnostics.Debug.WriteLine($"[MainLayout] Reset completed in {sw.ElapsedMilliseconds}ms");
        
        if (sw.ElapsedMilliseconds > 200)
        {
            System.Diagnostics.Debug.WriteLine($"[MainLayout] WARNING: Reset took longer than target 200ms");
        }

        _isResetDialogOpen = false;
    }

    private Task HandleResetCancel()
    {
        _isResetDialogOpen = false;
        return Task.CompletedTask;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        ServiceWorkerUpdateService.UpdateDetected -= OnServiceWorkerUpdateDetected;
    }
}


