@implements IAsyncDisposable
@inject IGitSimulatorService GitService
@inject IGraphRenderService GraphRender
@inject GraphRendererJsInterop GraphRenderer
@inject IThemeService ThemeService

<div class="commit-graph-panel"
     role="img"
     aria-label="@_ariaLabel"
     tabindex="0">
    @if (_showEmptyState)
    {
        <div class="empty-state">
            <div class="empty-state-border">
                <MudText>Initialise a repo with <code>git init</code> to see the commit graph.</MudText>
            </div>
        </div>
    }
    else
    {
        <div class="git-graph-container">
            <div id="git-graph"></div>
        </div>
    }
</div>

@code {
    private const string ContainerId = "git-graph";

    private string _ariaLabel = "Git graph: no repository initialised";
    private bool _showEmptyState = true;
    private CancellationTokenSource? _debounce;
    private bool _subscribed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!_subscribed)
        {
            GitService.StateChanged   += HandleStateChanged;
            ThemeService.ThemeChanged += HandleThemeChanged;
            _subscribed = true;
        }

        await GraphRenderer.InitAsync(ThemeService.IsDarkMode);
        await RenderCurrentGraphAsync();
    }

    private async void HandleStateChanged() => await ScheduleRenderAsync();

    private async void HandleThemeChanged()
    {
        try
        {
            await GraphRenderer.InitAsync(ThemeService.IsDarkMode);
            await ScheduleRenderAsync();
        }
        catch (Exception ex) when (ex is ObjectDisposedException or TaskCanceledException) { }
    }

    private async Task ScheduleRenderAsync()
    {
        lock (_debounce ?? new object())
        {
            _debounce?.Cancel();
            _debounce?.Dispose();
            _debounce = new CancellationTokenSource();
        }

        var token = _debounce.Token;
        try
        {
            await Task.Delay(50, token);
            try
            {
                await InvokeAsync(RenderCurrentGraphAsync);
            }
            catch (Exception) when (!token.IsCancellationRequested)
            {
                throw;
            }
        }
        catch (TaskCanceledException) { /* debounced away */ }
        catch
        {
            lock (_debounce ?? new object())
            {
                _debounce?.Dispose();
                _debounce = null;
            }
            throw;
        }
    }

    private async Task RenderCurrentGraphAsync()
    {
        var state = GitService.CurrentState;
        _showEmptyState = state?.IsInitialized != true;
        _ariaLabel = GraphRender.BuildAriaLabel(state);
        StateHasChanged();

        if (!_showEmptyState && state is not null)
        {
            var payload = GraphRender.BuildPayload(state);
            if (payload is not null)
            {
                try
                {
                    await GraphRenderer.RenderAsync(ContainerId, payload);
                    var reduceMotion = await GraphRenderer.GetReducedMotionAsync();
                    await GraphRenderer.ScrollToHeadAsync(ContainerId, reduceMotion);
                }
                catch (Exception ex) when (ex is JSException or TaskCanceledException) { }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        GitService.StateChanged   -= HandleStateChanged;
        ThemeService.ThemeChanged -= HandleThemeChanged;
        _debounce?.Cancel();
        _debounce?.Dispose();
        await GraphRenderer.DisposeAsync();
    }
}
