@* src/GitVisualizer/Components/Sandbox/TerminalPanel.razor *@
@inject IGitSimulatorService GitService
@inject IStorageMonitorService StorageService
@implements IDisposable

<div class="terminal-panel">

    <div class="terminal-toolbar">
        <span class="terminal-title">Terminal</span>
        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                       aria-label="Clear terminal output"
                       Size="Size.Small"
                       OnClick="HandleClearAsync" />
    </div>

    @if (GitService.IsProcessing)
    {
        <MudProgressLinear Class="terminal-progress" Indeterminate="true" />
    }

    @if (_storageStatus?.IsWarning == true)
    {
        <MudAlert Class="terminal-alert storage-alert"
                  Severity="Severity.Warning"
                  Dense="true"
                  OnClose="() => StateHasChanged()">
            <div>
                ⚠️ Storage at @($"{_storageStatus.UsagePercent:F0}%") — consider resetting the sandbox to free space
            </div>
        </MudAlert>
    }

    <div class="terminal-output" aria-live="polite">
        @foreach (var entry in GitService.CommandHistory)
        {
            <div class="terminal-entry">
                <div class="terminal-command">
                    <span class="terminal-prompt">$</span> @entry.Command
                </div>
                @if (entry.Result.Success)
                {
                    <pre class="terminal-output-text">@entry.Result.Output</pre>
                }
                else
                {
                    <MudAlert Class="terminal-alert" Severity="Severity.Warning" Dense="true">
                        @entry.Result.ErrorMessage
                        @if (!string.IsNullOrEmpty(entry.Result.SuggestedFix))
                        {
                            <span> @entry.Result.SuggestedFix</span>
                        }
                    </MudAlert>
                }
            </div>
        }
    </div>

    <div class="terminal-input-row">
        <span class="terminal-prompt">$</span>
        <textarea @ref="_inputRef"
                  class="terminal-input"
                  aria-label="Git command input"
                  rows="1"
                  disabled="@(_storageStatus?.IsBlocked == true)"
                  value="@_inputText"
                  @oninput="HandleInputChange"
                  @onkeydown="HandleKeyDownAsync"
                  placeholder="@(_storageStatus?.IsBlocked == true ? "Storage full — reset to continue" : "Enter git command...")"></textarea>
    </div>

    <StorageFullDialog @bind-IsOpen="_showStorageFullDialog" OnReset="HandleStorageFullResetAsync" />

</div>

@code {
    [Parameter]
    public EventCallback OnHelpRequested { get; set; }

    private ElementReference _inputRef;
    private string _inputText = string.Empty;
    private string _savedInput = string.Empty;
    private int _historyIndex = -1;
    private StorageStatus? _storageStatus;
    private bool _showStorageFullDialog;

    protected override async Task OnInitializedAsync()
    {
        GitService.StateChanged += OnServiceStateChanged;
        StorageService.OnStorageStatusChanged += OnStorageStatusChanged;
        
        // Initialize storage status on first load
        _storageStatus = await StorageService.GetStatusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await _inputRef.FocusAsync(); }
            catch (JSException) { }
        }
    }

    private void OnServiceStateChanged()
        => InvokeAsync(StateHasChanged);

    private void OnStorageStatusChanged(StorageStatus status)
    {
        _storageStatus = status;
        InvokeAsync(StateHasChanged);
    }

    private void HandleInputChange(ChangeEventArgs e)
        => _inputText = e.Value?.ToString() ?? string.Empty;

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter" when e.ShiftKey:
                _inputText += "\n";
                break;
            case "Enter" when !e.ShiftKey:
                await HandleSubmitAsync();
                break;
            case "ArrowUp":
                NavigateHistoryUp();
                break;
            case "ArrowDown":
                NavigateHistoryDown();
                break;
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (GitService.IsProcessing) return;

        var command = _inputText.Trim();
        if (string.IsNullOrEmpty(command)) return;

        // Check storage block threshold and show dialog
        if (_storageStatus?.IsBlocked == true)
        {
            _showStorageFullDialog = true;
            return;
        }

        _historyIndex = -1;
        _savedInput = string.Empty;

        if (command.Equals("clear", StringComparison.OrdinalIgnoreCase))
        {
            _inputText = string.Empty;
            await GitService.ClearAsync();
            return;
        }

        // Handle git help command
        if (command.Equals("git help", StringComparison.OrdinalIgnoreCase))
        {
            _inputText = string.Empty;
            await OnHelpRequested.InvokeAsync();
            try { await _inputRef.FocusAsync(); }
            catch (JSException) { }
            return;
        }

        _inputText = string.Empty;
        try
        {
            await GitService.ExecuteCommandAsync(command);
            
            // Check storage after command execution
            _storageStatus = await StorageService.GetStatusAsync();
        }
        catch
        {
            _inputText = command; // restore on failure so the user can retry
            throw;
        }
        try { await _inputRef.FocusAsync(); }
        catch (JSException) { }
    }

    private async Task HandleStorageFullResetAsync()
    {
        try
        {
            await GitService.ResetAsync();
            _storageStatus = await StorageService.GetStatusAsync();
            try { await _inputRef.FocusAsync(); }
            catch (JSException) { }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[TerminalPanel] Error during storage full reset: {ex.Message}");
        }
    }

    private void NavigateHistoryUp()
    {
        var history = GitService.CommandHistory;
        if (history.Count == 0) return;

        if (_historyIndex == -1)
            _savedInput = _inputText;

        var newIndex = _historyIndex + 1;
        if (newIndex >= history.Count) return;

        _historyIndex = newIndex;
        _inputText = history[history.Count - 1 - _historyIndex].Command;
    }

    private void NavigateHistoryDown()
    {
        if (_historyIndex <= 0)
        {
            _historyIndex = -1;
            _inputText = _savedInput;
            return;
        }

        _historyIndex--;
        var history = GitService.CommandHistory;
        _inputText = history[history.Count - 1 - _historyIndex].Command;
    }

    private async Task HandleClearAsync()
    {
        _historyIndex = -1;
        _savedInput = string.Empty;
        await GitService.ClearAsync();
    }

    public void Dispose()
    {
        GitService.StateChanged -= OnServiceStateChanged;
        StorageService.OnStorageStatusChanged -= OnStorageStatusChanged;
    }
}

