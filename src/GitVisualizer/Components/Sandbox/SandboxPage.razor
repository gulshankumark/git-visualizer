@page "/"
@using GitVisualizer.Components.Mobile
@using GitVisualizer.Interop
@inject ViewportJsInterop ViewportJs
@implements IAsyncDisposable

<PageTitle>git-visualizer</PageTitle>

@if (_isMobile)
{
    <div class="mobile-layout">
        <div class="mobile-panel-content">
            @if (_activeTab == "Terminal")
            {
                <div id="terminal-panel">
                    <TerminalPanel @ref="_terminalPanel" OnHelpRequested="ShowHelp" />
                </div>
            }
            else
            {
                <div id="graph-panel">
                    <CommitGraphPanel />
                </div>
            }
        </div>
        <MobileTabBar ActiveTab="@_activeTab"
                      OnTabChange="@(t => { _activeTab = t; StateHasChanged(); })" />
    </div>
}
else
{
    <SplitPane>
        <LeftContent>
            <TerminalPanel @ref="_terminalPanel" OnHelpRequested="ShowHelp" />
        </LeftContent>
        <RightContent>
            <CommitGraphPanel />
        </RightContent>
    </SplitPane>
}

<HelpOverlay @ref="_helpOverlay" />

<!-- Session restore toast -->
<MudSnackbarProvider />

<!-- Schema mismatch alert -->
@if (_showSchemaMismatchAlert)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="fixed-alert">
        Your previous session was from an older version and could not be restored.
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" 
                   OnClick="@(() => _showSchemaMismatchAlert = false)">
            Dismiss
        </MudButton>
    </MudAlert>
}

@code {
    [Inject]
    private IGitSimulatorService? GitSimulator { get; set; }

    [Inject]
    private ISnackbar? Snackbar { get; set; }

    private TerminalPanel? _terminalPanel;
    private HelpOverlay? _helpOverlay;
    private bool _showSchemaMismatchAlert;
    private bool _alertsShown;
    private bool _initialized;
    private bool _isMobile;
    private string _activeTab = "Terminal";
    private DotNetObjectReference<SandboxPage>? _dotnetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Viewport detection — must happen before git init so layout is correct
            _isMobile = await ViewportJs.IsMobileAsync();
            _dotnetRef = DotNetObjectReference.Create(this);
            await ViewportJs.SubscribeAsync(_dotnetRef);
            StateHasChanged();
        }

        if (firstRender && !_initialized && GitSimulator != null && Snackbar != null)
        {
            _initialized = true;
            
            try
            {
                // Initialize session storage
                await GitSimulator.InitializeAsync();

                // Show restore toast if session was restored
                if (GitSimulator.SessionRestored && !_alertsShown)
                {
                    Snackbar.Add("Session restored ✓", Severity.Success, config =>
                    {
                        config.VisibleStateDuration = 2000;
                        config.HideTransitionDuration = 300;
                    });
                    _alertsShown = true;
                }

                // Show schema mismatch alert if version changed
                if (GitSimulator.SchemaMismatch && !_showSchemaMismatchAlert)
                {
                    _showSchemaMismatchAlert = true;
                }

                // Final state update
                if (GitSimulator.SessionRestored || GitSimulator.SchemaMismatch)
                {
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[SandboxPage] Error during initialization: {ex.Message}");
            }
        }
    }

    /// <summary>Invoked by viewport-interop.js when the viewport crosses the 768px breakpoint.</summary>
    [JSInvokable]
    public void OnBreakpointChanged(bool isMobile)
    {
        _isMobile = isMobile;
        if (!_isMobile) _activeTab = "Terminal"; // reset tab on expand back to desktop
        InvokeAsync(StateHasChanged);
    }

    private void ShowHelp()
        => _helpOverlay?.Open();

    public async ValueTask DisposeAsync()
    {
        try { await ViewportJs.UnsubscribeAsync(); }
        catch (Exception ex) when (ex is JSException or TaskCanceledException) { }
        _dotnetRef?.Dispose();
    }
}

<style>
.fixed-alert {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    max-width: 90vw;
}
</style>